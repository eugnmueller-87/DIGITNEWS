# Normalize line endings to LF in the repo (matches Prettier endOfLine:lf and
# Ruff). Prevents CRLF/LF churn between Windows and Linux/CI.
* text=auto eol=lf

# Binary files — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
