# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# python worker
worker/.venv/
worker/**/__pycache__/
worker/**/*.pyc
worker/.mypy_cache/
worker/.ruff_cache/
worker/.pytest_cache/
worker/**/*.egg-info/
worker/build/
worker/dist/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# secrets / keys — never commit (belt-and-suspenders alongside .env* below)
*.key
*.p8
*.p12
secrets/
vapid.json

# supabase local dev artifacts (keep migrations + config.toml, ignore volumes)
/supabase/.branches
/supabase/.temp
/supabase/.env

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — all ignored by default; .env.example is the ONLY tracked template
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
