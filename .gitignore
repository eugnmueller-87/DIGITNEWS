# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# python worker
worker/.venv/
worker/**/__pycache__/
worker/**/*.pyc
worker/.mypy_cache/
worker/.ruff_cache/
worker/.pytest_cache/
worker/**/*.egg-info/
worker/build/
worker/dist/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# secrets / keys — never commit (belt-and-suspenders alongside .env* below)
*.key
*.p8
*.p12
secrets/
vapid.json

# Android signing — NEVER commit the upload keystore or its passwords
*.jks
*.keystore
android/keystore.properties
android/app/release/

# Capacitor / Android local + build artifacts
android/local.properties
android/.gradle/
android/build/
android/app/build/

# supabase local dev artifacts (keep migrations + config.toml, ignore volumes)
/supabase/.branches
/supabase/.temp
/supabase/.env

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — all ignored by default; .env.example is the ONLY tracked template
.env
.env.*
!.env.example

# vercel
.vercel

# local Claude settings (per-machine; not shared)
.claude/settings.local.json

# out-of-tree deliverable scratch dir (not part of the app)
_fp-build/

# local copy of the final-project n8n POC workflows (live in the final-project-eugen repo, not this one)
poc-workflows/

# local source video/GIF for the final-project demo (committed to final-project-eugen, not this repo)
clip/

# MCP server config — holds a Supabase access token (root credential). NEVER
# commit. Use .mcp.json.example as the tracked template instead.
.mcp.json

# typescript
*.tsbuildinfo
next-env.d.ts
deploy-command.local.txt
