{
  "//": "Template for the Supabase MCP server. Copy to .mcp.json (gitignored) and replace the placeholder token. The access token is a ROOT credential for the whole Supabase account — never commit the real .mcp.json.",
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=nlcqqykrieqgivjstrma"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "sbp_REPLACE_WITH_YOUR_PERSONAL_ACCESS_TOKEN"
      }
    }
  }
}
